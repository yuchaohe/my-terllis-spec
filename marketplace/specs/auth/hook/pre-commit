#!/bin/bash

# 1. 找到权限清单文件
ALLOWLIST=".trellis/auth/app-allowlist.json"

# 如果清单文件不存在，就不拦（你可以改成拦住）
if [ ! -f "$ALLOWLIST" ]; then
  echo "⚠️ 没找到权限清单，跳过校验"
  exit 0
fi

# 2. 拿到"当前是谁在提交"（读 git 配置里的邮箱）
DEVELOPER=$(git config user.email)

# 3. 拿到"这次提交改了哪些文件"
CHANGED_FILES=$(git diff --cached --name-only)

# 4. 检查改的文件属于哪个应用
#    假设你们的目录结构是 apps/order-service/xxx.java
#    我们就看改的文件路径里有没有 apps/xxx-service/
for FILE in $CHANGED_FILES; do
  # 从文件路径里提取应用名，比如 apps/order-service/xxx → order-service
  if echo "$FILE" | grep -q "^apps/"; then
    APP_NAME=$(echo "$FILE" | sed 's|^apps/\([^/]*\)/.*|\1|')

    # 5. 用 jq 工具查清单：这个人在不在允许列表里？
    #    jq 是一个处理 JSON 的命令行工具，Mac/Linux 一般自带或 brew install jq
    ALLOWED=$(jq -r --arg app "$APP_NAME" '.apps[$app].developers // [] | index("'"$DEVELOPER"'")' "$ALLOWLIST")

    if [ "$ALLOWED" = "null" ]; then
      echo ""
      echo "❌ 权限不足！"
      echo "   开发者: $DEVELOPER"
      echo "   应用:   $APP_NAME"
      echo "   文件:   $FILE"
      echo ""
      echo "   你不在 $APP_NAME 的 developers 列表中，无法提交。"
      echo "   请联系管理员修改 .trellis/auth/app-allowlist.json"
      exit 1
    fi
  fi
done

echo "✅ 权限校验通过"
exit 0